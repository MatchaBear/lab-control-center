# Local lab bootstrap overrides
# This file is sourced by: $REPO_DIR/bootstrap-lab.sh

# libvirt networks to ensure/start
# Keep default plus the NAC-specific dual-NIC networks.
VM_NETWORKS="default nac-mgmt nac-data"

# Delay between VM starts (seconds)
START_DELAY_SECONDS=30

# Startup order (space-separated VM names)
# Keep core infra first, heavy nodes later.
LAB_VMS="eve-ng"
